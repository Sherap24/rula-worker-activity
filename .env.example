# Copy to .env and adjust for your machine (do not commit .env).
#
# External data root — datasets must NOT live inside the OneDrive project folder.
# See docs/DATA_ACQUISITION.md for directory layout.
RULA_DATA_ROOT=C:\Users\YOUR_USERNAME\Datasets\RULA

# Optional: override repository-relative output directory name (default: outputs)
# RULA_OUTPUT_DIR=outputs

# Optional: enable ffprobe metadata when FFmpeg is installed (default: false)
# RULA_USE_FFPROBE=false
